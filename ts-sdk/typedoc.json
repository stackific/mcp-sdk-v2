{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/client/index.ts", "src/server/index.ts", "src/server/node.ts", "src/index.ts"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "hideGenerator": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "sort": ["source-order"],
  "gitRevision": "main"
}
