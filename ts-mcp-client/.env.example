# ── MCP server endpoints (the app is server-agnostic — point these at any compliant server) ──
# Main MCP endpoint (Streamable HTTP). See ../MCP_SERVER_REQUIREMENTS.md.
MCP_SERVER_URL=http://localhost:8001/mcp
# OAuth Authorization Server + protected resource (used only by the Authorization page).
AUTH_SERVER_URL=http://localhost:8003

# ── Sampling (DeepSeek via the Anthropic-compatible endpoint) ──
# Backs the Sampling page. If unset, the backend returns a deterministic mock so the app still runs.
DEEPSEEK_API_KEY=

# Optional overrides:
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_MODEL=deepseek-chat
# BACKEND_PORT=8002
# FRONTEND_URL=http://localhost:8000
